# ===== Fashion Bot Scrapper - Configuração =====

# Conexão PostgreSQL (obrigatório)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/botdb

# Quantidade de browsers stealth simultâneos (cada um usa ~300-500MB RAM)
# VPS 4GB → 3 | VPS 8GB → 6
WORKER_COUNT=3

# Timeout máximo por request em segundos
REQUEST_TIMEOUT=120
