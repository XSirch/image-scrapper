# ===== Fashion Bot Scrapper - Configuração =====

# Conexão PostgreSQL (obrigatório)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/botdb

# Quantidade de browsers stealth simultâneos (cada um usa ~300-500MB RAM)
# VPS 4GB → 3 | VPS 8GB → 6
WORKER_COUNT=3

# Timeout máximo por request em segundos
REQUEST_TIMEOUT=120

# Browser visivel para resolver challenges manualmente (ex: SHEIN)
BROWSER_HEADLESS=true

# Diretorio base para perfis persistentes por worker (cookies/local storage)
# Ex: .browser-profiles
BROWSER_USER_DATA_DIR=

# Tempo para resolver challenge manual da SHEIN no navegador visivel
SHEIN_MANUAL_WAIT_SECONDS=0

# ===== CAPTCHA Solving (SolveCaptcha) =====
# Obtenha sua chave em: https://solvecaptcha.com/
# Suporta: Cloudflare Turnstile (Temu), reCAPTCHA v2/v3, GeeTest (Shein), FunCaptcha
# Deixe vazio para desativar o solving automático de CAPTCHA
SOLVECAPTCHA_API_KEY=

# ===== Managed Scraping API Fallback =====
# O motor local roda primeiro. A API externa so e chamada quando o motor local
# retorna 0 imagens ou encontra um bloqueio anti-bot terminal.
# Opcoes: scrapedo | scrapingbee | none
SCRAPING_API_FALLBACK=scrapedo
SCRAPEDO_TOKEN=
SCRAPINGBEE_API_KEY=
SCRAPING_API_RENDER=true
SCRAPING_API_SUPER=true
SCRAPING_API_COUNTRY_CODE=br
SCRAPING_API_MAX_IMAGES=10
SCRAPINGBEE_LIMITED_EXTRACT_RULES=true
SCRAPINGBEE_STEALTH_ENABLED=true
SCRAPINGBEE_STEALTH_DOMAINS=shein,shopee,temu
